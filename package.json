{
  "name": "talent-management-system",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @talent/client dev",
    "dev:server": "pnpm --filter @talent/server dev",
    "dev:all": "pnpm -r --parallel dev",
    "build": "pnpm --filter @talent/types build && pnpm -r build",
    "build:client": "pnpm --filter @talent/client build",
    "build:server": "pnpm --filter @talent/server build",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r clean && rm -rf node_modules",
    "db:push": "pnpm --filter @talent/server db:push",
    "db:generate": "pnpm --filter @talent/server db:generate",
    "db:seed": "pnpm --filter @talent/server db:seed"
  },
  "devDependencies": {
    "typescript": "~5.9.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0"
}
