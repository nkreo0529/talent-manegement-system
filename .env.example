# ===========================================
# タレントマネジメントシステム 環境変数設定
# ===========================================
# このファイルをコピーして .env を作成してください
# cp .env.example .env

# -------------------------------------------
# Supabase設定（必須）
# -------------------------------------------
# Supabaseダッシュボード → Settings → API から取得

# Project URL
VITE_SUPABASE_URL=https://your-project.supabase.co

# anon public key（フロントエンド用）
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# -------------------------------------------
# サーバーサイド設定（API機能用）
# -------------------------------------------

# Supabase URL（Vercel Serverless Functions用）
SUPABASE_URL=https://your-project.supabase.co

# service_role key（管理者権限、サーバーサイドのみ）
# ⚠️ この値は絶対にフロントエンドに公開しないでください
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# -------------------------------------------
# Anthropic API設定（AI機能用）
# -------------------------------------------
# https://console.anthropic.com/ から取得

ANTHROPIC_API_KEY=sk-ant-api03-...

# -------------------------------------------
# オプション設定
# -------------------------------------------

# デモモードを強制（Supabase未設定でも動作確認用）
# VITE_DEMO_MODE=true

# 開発環境フラグ
# NODE_ENV=development
