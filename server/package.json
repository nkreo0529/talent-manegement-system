    "db:seed": "tsx src/db/seed.ts"
  },
  "dependencies": {
    "@talent/types": "workspace:*",
    "@anthropic-ai/sdk": "^0.32.1",
    "@hono/node-server": "^1.13.7",
    "@hono/zod-validator": "^0.4.2",
    "@neondatabase/serverless": "^0.10.4",
    "better-auth": "^1.1.14",
    "drizzle-orm": "^0.41.0",
    "hono": "^4.6.16",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "drizzle-kit": "^0.31.4",
    "tsx": "^4.19.2",
    "typescript": "~5.9.3"
  }
